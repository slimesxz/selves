const functions = require("firebase-functions");
const admin = require("firebase-admin");
const { Resend } = require("resend");
const fs = require("fs");

admin.initializeApp();
const db = admin.firestore();
const resend = new Resend("re_5iPnzUwA_HnS7tWyRr25jUMwtSygDpacP");

function generateCode() {
  const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  let code = "";
  for (let i = 0; i < 6; i++) {
    code += chars.charAt(Math.floor(Math.random() * chars.length));
  }
  return code;
}

function emailTemplate(code) {
  const html = fs.readFileSync(__dirname + "/email.html", "utf8");
  return html.replace(/\{\{CODE\}\}/g, code);
}

exports.waitlistEmail = functions.https.onRequest(async (req, res) => {
  res.set("Access-Control-Allow-Origin", "*");
  if (req.method === "OPTIONS") {
    res.set("Access-Control-Allow-Methods", "POST");
    res.set("Access-Control-Allow-Headers", "Content-Type");
    return res.status(204).send("");
  }

  const email = req.body.email;
  const ref = req.body.ref || null;

  try {
    const existing = await db.collection("waitlist").where("email", "==", email).get();
    if (!existing.empty) {
      return res.status(200).send("duplicate");
    }

    const code = generateCode();

    await db.collection("waitlist").add({
      email: email,
      code: code,
      referredBy: ref,
      createdAt: new Date(),
      status: "waitlisted"
    });

    if (ref) {
      const referrerSnap = await db.collection("waitlist").where("code", "==", ref).get();
      if (!referrerSnap.empty) {
        const referrer = referrerSnap.docs[0].data();
        await db.collection("connections").add({
          from: referrer.email,
          to: email,
          fromCode: ref,
          status: "pending",
          createdAt: new Date()
        });
        await referrerSnap.docs[0].ref.update({
          referralCount: admin.firestore.FieldValue.increment(1)
        });
      }
    }

    await resend.emails.send({
      from: "Selves <info@selves.id>",
      to: email,
      subject: "Know yourself.",
      html: emailTemplate(code)
    });

    await resend.emails.send({
      from: "Selves <info@selves.id>",
      to: "info@selves.id",
      subject: "New signup",
      html: "<p>" + email + " — code: " + code + "</p>"
    });

    res.status(200).send("ok");

  } catch (err) {
    console.error("FUNCTION ERROR:", err);
    res.status(500).send(err.toString());
  }
});
