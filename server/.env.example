# Selves server — local development environment TEMPLATE.
# Copy to `.env` (gitignored) and replace every <...> placeholder with a
# local-only SYNTHETIC value. NO production credentials belong in either file.
# Placeholders only here.

# Superuser connection (docker POSTGRES_USER). Bootstrap principal + Phase-3
# tests only; never used by app/worker/migrations.
DATABASE_URL=postgres://selves:<superuser-local-password>@localhost:5432/selves_dev
TEST_DATABASE_URL=postgres://selves:<superuser-local-password>@localhost:5432/selves_test

# ── Phase 4: managed roles ──────────────────────────────────────────────────
# EXACT governed-database allowlist (comma-separated, no wildcards).
SELVES_GOVERNED_DATABASES=selves_dev,selves_test

# Role passwords: SYNTHETIC, local-only. The server generates the SCRAM verifier
# at bootstrap; these plaintexts must never reach argv, logs, or tracked files.
SELVES_MIGRATE_PASSWORD=<synthetic-local-migrate-password>
SELVES_APP_PASSWORD=<synthetic-local-app-password>
SELVES_WORKER_PASSWORD=<synthetic-local-worker-password>
SELVES_BOOTSTRAP_PASSWORD=<synthetic-local-bootstrap-password>
SELVES_OPERATOR_PASSWORD=<synthetic-local-operator-password>

# Role connection URLs — development. Migrations run as selves_migrate with
# current_user=selves_owner (via the libpq `options` role switch).
MIGRATE_DATABASE_URL=postgres://selves_migrate:<synthetic-local-migrate-password>@localhost:5432/selves_dev?options=-c%20role%3Dselves_owner
APP_DATABASE_URL=postgres://selves_app:<synthetic-local-app-password>@localhost:5432/selves_dev
WORKER_DATABASE_URL=postgres://selves_worker:<synthetic-local-worker-password>@localhost:5432/selves_dev
BOOTSTRAP_DATABASE_URL=postgres://selves_bootstrap:<synthetic-local-bootstrap-password>@localhost:5432/selves_dev
OPERATOR_DATABASE_URL=postgres://selves_operator:<synthetic-local-operator-password>@localhost:5432/selves_dev

# Role connection URLs — test.
TEST_MIGRATE_DATABASE_URL=postgres://selves_migrate:<synthetic-local-migrate-password>@localhost:5432/selves_test?options=-c%20role%3Dselves_owner
TEST_APP_DATABASE_URL=postgres://selves_app:<synthetic-local-app-password>@localhost:5432/selves_test
TEST_WORKER_DATABASE_URL=postgres://selves_worker:<synthetic-local-worker-password>@localhost:5432/selves_test
TEST_BOOTSTRAP_DATABASE_URL=postgres://selves_bootstrap:<synthetic-local-bootstrap-password>@localhost:5432/selves_test
TEST_OPERATOR_DATABASE_URL=postgres://selves_operator:<synthetic-local-operator-password>@localhost:5432/selves_test
