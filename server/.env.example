# Selves server — local development environment.
# Copy to `.env` (gitignored). Local-only values; NO production credentials.
# These must match the credentials in ../docker-compose.yml.

# Development database (used by `npm run migrate`).
DATABASE_URL=postgres://selves:selves_local_dev@localhost:5432/selves_dev

# Isolated test database (used by `npm run migrate:test`).
# Provisioned by server/db/init on first container start.
TEST_DATABASE_URL=postgres://selves:selves_local_dev@localhost:5432/selves_test
