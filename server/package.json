{
  "name": "@selves/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Selves authoritative server: migrations and (later) API, authorization, worker.",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "bootstrap": "bash ./bootstrap/bootstrap.sh",
    "start": "node --env-file=.env src/server.ts",
    "migrate": "node --env-file=.env ./node_modules/node-pg-migrate/bin/node-pg-migrate.js up -d MIGRATE_DATABASE_URL",
    "migrate:down": "node --env-file=.env ./node_modules/node-pg-migrate/bin/node-pg-migrate.js down -d MIGRATE_DATABASE_URL",
    "migrate:test": "node --env-file=.env ./node_modules/node-pg-migrate/bin/node-pg-migrate.js up -d TEST_MIGRATE_DATABASE_URL",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:reset": "docker compose -f ../docker-compose.yml down -v && docker compose -f ../docker-compose.yml up -d",
    "db:health": "docker compose -f ../docker-compose.yml ps",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.2",
    "@fastify/cors": "11.3.0",
    "fastify": "5.10.0",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/pg": "^8.11.10",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
